# ─── Lindoffs Familjearkiv — Environment variables ───────────────────────────
#
# Kopiera den här filen till .env.local och fyll i dina värden.
# .env.local läggs INTE upp i Git (se .gitignore).
#
# Usage:
#   cp .env.example .env.local
#   # Redigera .env.local med dina värden
#   npm run dev

# ─── Lösenordsskydd ───────────────────────────────────────────────────────────
#
# Sätter du den här variabeln aktiveras inloggningssidan automatiskt.
# Lämna den tom (eller kommentera ut den) för att stänga av skyddet.
#
# FAMILY_SITE_PASSWORD=lindoff2024

# ─── (Framtida) CMS-integration ──────────────────────────────────────────────
#
# Sanity
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=
#
# Notion
# NOTION_TOKEN=
# NOTION_PERSONS_DB_ID=
#
# Extern databas
# DATABASE_URL=

# ─── Supabase ────────────────────────────────────────────────────────────────
#
# Supabase Project URL and Anon Key
# Get these from your Supabase project settings
#
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
